{
  "info": {
    "_postman_id": "c0f5d08e-0d1a-4e66-9c34-8d0f2b8c1a11",
    "name": "Lab6 Kafka KRaft Microservices",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for testing the Spring Boot Kafka KRaft lab services."
  },
  "variable": [
    {
      "key": "gatewayUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "orderServiceUrl",
      "value": "http://localhost:8081"
    },
    {
      "key": "inventoryServiceUrl",
      "value": "http://localhost:8082"
    },
    {
      "key": "billingServiceUrl",
      "value": "http://localhost:8083"
    }
  ],
  "item": [
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order Through Gateway",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 202\", function () {",
                  "    pm.response.to.have.status(202);",
                  "});",
                  "",
                  "pm.test(\"Response confirms publish\", function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.message).to.eql(\"Order Created & Event Published\");",
                  "    pm.expect(jsonData.orderId).to.eql(\"ORD-1001\");",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"ORD-1001\",\n  \"item\": \"Laptop\",\n  \"quantity\": 1\n}"
            },
            "url": {
              "raw": "{{gatewayUrl}}/orders",
              "host": [
                "{{gatewayUrl}}"
              ],
              "path": [
                "orders"
              ]
            },
            "description": "Primary lab flow. Sends an order through the API Gateway to the Order Service."
          },
          "response": []
        },
        {
          "name": "Create Second Order Through Gateway",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"ORD-1002\",\n  \"item\": \"Phone\",\n  \"quantity\": 2\n}"
            },
            "url": {
              "raw": "{{gatewayUrl}}/orders",
              "host": [
                "{{gatewayUrl}}"
              ],
              "path": [
                "orders"
              ]
            },
            "description": "Use this to prove both consumer services react to multiple events."
          },
          "response": []
        },
        {
          "name": "List Orders From Order Service",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Status is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response is an array\", function () {",
                  "    pm.expect(pm.response.json()).to.be.an(\"array\");",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{orderServiceUrl}}/orders",
              "host": [
                "{{orderServiceUrl}}"
              ],
              "path": [
                "orders"
              ]
            },
            "description": "Reads the in-memory orders stored by the Order Service."
          },
          "response": []
        },
        {
          "name": "Create Invalid Order",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Validation fails\", function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([400, 500]);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": \"\",\n  \"item\": \"Laptop\",\n  \"quantity\": 0\n}"
            },
            "url": {
              "raw": "{{gatewayUrl}}/orders",
              "host": [
                "{{gatewayUrl}}"
              ],
              "path": [
                "orders"
              ]
            },
            "description": "Checks request validation for blank orderId and non-positive quantity."
          },
          "response": []
        }
      ]
    },
